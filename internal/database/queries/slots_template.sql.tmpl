UPDATE {{.AssignTable}} SET
    file_id = NULL,
    updated_at = CURRENT_TIMESTAMP
WHERE slot_id = ?;

-- =====================
-- {{.EntityType}} Review Queue Queries
-- =====================

-- name: Count{{.EntityType}}FilesWithoutSlot :one
SELECT COUNT(*) FROM {{.FileTable}} WHERE slot_id IS NULL;

-- name: List{{.EntityType}}FilesWithoutSlot :many
SELECT {{.FileAlias}}.*, {{.FileTitleCols}}
FROM {{.FileTable}} {{.FileAlias}}
{{.FileEntityJoins}}
WHERE {{.FileAlias}}.slot_id IS NULL
ORDER BY {{.FileTitleOrder}};
